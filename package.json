{
  "name": "idena-sdk-js-lite",
  "version": "0.2.0",
  "description": "Idena SDK Javascript package - lite version",
  "type": "module",
  "files": [
    "/dist"
  ],
  "cdn": "dist/index.umd.js",
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "unpkg": "dist/index.umd.js",
  "module": "dist/index.esm.js",
  "jsdelivr": "dist/index.umd.js",
  "umd:main": "dist/index.umd.js",
  "exports": {
    ".": [
      {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./dist/index.js"
    ]
  },
  "scripts": {
    "doc": "typedoc src/index.ts --gitRevision master",
    "test": "npm run test:lint && npm run test:unit",
    "test:lint": "eslint \"*/**/*.{ts,js,json}\"",
    "test:unit": "vitest run",
    "lint": "eslint \"*/**/*.{ts,js,json}\" --fix",
    "build": "rollup --config ./rollup.config.js",
    "update-docs": "npm run doc && npm run build",
    "prepublishOnly": "npm run update-docs && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubiubi18/idena-sdk-js-lite.git"
  },
  "keywords": [],
  "author": {
    "name": "idena"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ubiubi18/idena-sdk-js-lite/issues"
  },
  "homepage": "https://github.com/ubiubi18/idena-sdk-js-lite#readme",
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.2",
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "^2.3.0",
    "bn.js": "^5.2.2",
    "decimal.js": "^10.6.0",
    "js-sha3": "^0.9.3"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@types/bn.js": "^5.2.0",
    "@types/eslint": "^9.6.1",
    "@types/prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jiti": "^2.6.1",
    "long": "^5.3.2",
    "prettier": "^3.7.4",
    "protobufjs": "^8.0.0",
    "rollup": "^4.54.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-typescript2": "^0.37.0",
    "ts-proto": "2.11.10",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typedoc-plugin-missing-exports": "^4.1.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.16"
  }
}
