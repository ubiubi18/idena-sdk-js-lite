{
  "name": "idena-sdk-js-lite",
  "version": "0.2.0",
  "description": "Idena SDK Javascript package - lite version",
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0"
  },
  "files": [
    "/dist"
  ],
  "cdn": "dist/index.umd.js",
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "unpkg": "dist/index.umd.js",
  "module": "dist/index.esm.js",
  "jsdelivr": "dist/index.umd.js",
  "umd:main": "dist/index.umd.js",
  "exports": {
    ".": [
      {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./dist/index.js"
    ]
  },
  "scripts": {
    "doc": "typedoc src/index.ts --gitRevision master",
    "test": "npm run test:lint && npm run test:unit",
    "test:lint": "eslint \"*/**/*.{ts,js,json}\"",
    "test:unit": "vitest run",
    "lint": "eslint \"*/**/*.{ts,js,json}\" --fix",
    "build": "npm run build:types && rollup --config ./rollup.config.js && npm run build:trim-dist",
    "build:trim-dist": "node ./scripts/trim-dist-whitespace.mjs",
    "build:types": "tsc -p tsconfig.bundle.json --emitDeclarationOnly",
    "update-docs": "npm run doc && npm run build",
    "prepublishOnly": "npm run update-docs && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubiubi18/idena-sdk-js-lite.git"
  },
  "keywords": [],
  "author": {
    "name": "idena"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ubiubi18/idena-sdk-js-lite/issues"
  },
  "homepage": "https://github.com/ubiubi18/idena-sdk-js-lite#readme",
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.2",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "bn.js": "^5.2.2",
    "decimal.js": "^10.6.0",
    "js-sha3": "^0.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/bn.js": "^5.2.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jiti": "^2.6.1",
    "prettier": "^3.7.4",
    "rollup": "^4.54.0",
    "rollup-plugin-dts": "^6.3.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.16"
  },
  "allowScripts": {
    "fsevents": false
  }
}
